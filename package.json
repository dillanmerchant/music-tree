{
  "name": "music-tree",
  "version": "0.1.0",
  "description": "DJ Helper for managing song connections and transitions",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run db:setup && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --port 5174 --strictPort",
    "dev:electron": "wait-on http://localhost:5174 && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "npm run build:seed-db && vite build && npm run build:electron",
    "build:seed-db": "node scripts/create-seed-db.js",
    "build:electron": "electron-builder",
    "postinstall": "prisma generate",
    "db:setup": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env');console.log('Created .env from .env.example');}\" && prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "better-sqlite3": "^11.6.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "music-metadata": "^10.6.1",
    "node-id3": "^0.2.6",
    "spotify-url-info": "^3.2.18",
    "youtube-dl-exec": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.musictree.app",
    "productName": "Music Tree",
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": [
      "node_modules/.prisma/**",
      "node_modules/@prisma/engines/**",
      "node_modules/better-sqlite3/**",
      "node_modules/youtube-dl-exec/**"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "node_modules/**/*",
      "!node_modules/**/README*",
      "!node_modules/**/*.md",
      {
        "from": "node_modules/.prisma/client/",
        "to": "node_modules/.prisma/client/"
      }
    ],
    "extraResources": [
      {
        "from": "prisma/music-tree.db",
        "to": "prisma/music-tree.db"
      },
      {
        "from": "prisma/schema.prisma",
        "to": "prisma/schema.prisma"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.music",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Audio"
    }
  }
}
